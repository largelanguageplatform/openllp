# The pdf-agent needs an OpenLLP API key to request signed upload URLs.
# Generate one at http://localhost:4000 and paste it here.
LLP_API_KEY=

# Where the platform's HTTP API lives (for requesting signed upload URLs).
LLP_API_URL=http://localhost:4000/api/v1

# Optional: also connect to the platform as an agent named "pdf-agent".
# USE_PLATFORM=1
# LLP_URL=ws://localhost:4000/agent/websocket

# LLM used to fabricate document contents (Ollama-compatible).
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

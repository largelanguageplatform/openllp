<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Platform" suffix=" · OpenLLP">
      {assigns[:page_title]}
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;800&family=DM+Serif+Display:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        const setActiveThemeAttr = () => {
          const theme = localStorage.getItem("phx:theme") || "system";
          let active = theme;
          if (theme === "system") {
            const prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
            active = prefersDark ? "dark" : "light";
          }
          document.documentElement.setAttribute("data-active-theme", active);
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        setActiveThemeAttr();
        window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", setActiveThemeAttr);
        window.addEventListener("storage", (e) => {
          if (e.key === "phx:theme") {
            setTheme(e.newValue || "system");
            setActiveThemeAttr();
          }
        });

        window.addEventListener("phx:set-theme", (e) => {
          setTheme(e.target.dataset.phxTheme);
          setActiveThemeAttr();
        });
      })();
    </script>
    <%= if measurement_id = Application.get_env(:platform, :ga4_measurement_id) do %>
      <!-- Google tag (gtag.js) -->
      <script async src={"https://www.googletagmanager.com/gtag/js?id=#{measurement_id}"}>
      </script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '<%= measurement_id %>');
      </script>
    <% end %>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
